{
    "openapi": "3.0.3",
    "info": {
        "title": "UniVote API Documentation",
        "description": "REST API specification for the UniVote ACSES UMaT E-Voting System. Administrative actions require bearer tokens.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api",
            "description": "Base Server"
        }
    ],
    "paths": {
        "/auth/send-otp": {
            "post": {
                "summary": "Request login OTP",
                "description": "Generates and sends an OTP code (email/SMS fallback) for voter authentication.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "studentId": {
                                        "type": "string",
                                        "example": "90123456789"
                                    }
                                },
                                "required": [
                                    "studentId"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OTP generated and dispatched successfully."
                    },
                    "400": {
                        "description": "Invalid input formatting."
                    },
                    "404": {
                        "description": "User registry entry not found."
                    }
                }
            }
        },
        "/auth/verify-otp": {
            "post": {
                "summary": "Verify OTP and Login",
                "description": "Submits the received OTP code to complete authentication and receive a JWT token.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "studentId": {
                                        "type": "string",
                                        "example": "90123456789"
                                    },
                                    "otpCode": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                },
                                "required": [
                                    "studentId",
                                    "otpCode"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Authentication successful.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "token": {
                                            "type": "string"
                                        },
                                        "user": {
                                            "$ref": "#/components/schemas/User"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid or expired OTP code."
                    }
                }
            }
        },
        "/auth/admin/register": {
            "post": {
                "summary": "Register System Administrator",
                "description": "Registers a new administrative or auditor account.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Super Admin"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "admin@umat.edu.gh"
                                    },
                                    "studentId": {
                                        "type": "string",
                                        "example": "ADMIN-001"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "password123"
                                    }
                                },
                                "required": [
                                    "name",
                                    "email",
                                    "studentId",
                                    "password"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Administrator account registered."
                    },
                    "409": {
                        "description": "Reference ID already exists."
                    }
                }
            }
        },
        "/auth/admin/login": {
            "post": {
                "summary": "Administrator Login",
                "description": "Authenticates administrative users with email/ID and password.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "studentId": {
                                        "type": "string",
                                        "example": "ADMIN-001"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "password123"
                                    }
                                },
                                "required": [
                                    "studentId",
                                    "password"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Administrative authorization granted.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "token": {
                                            "type": "string"
                                        },
                                        "user": {
                                            "$ref": "#/components/schemas/User"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid credentials."
                    }
                }
            }
        },
        "/elections": {
            "get": {
                "summary": "List all elections",
                "responses": {
                    "200": {
                        "description": "Array of configured elections.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Election"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "summary": "Create new election",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "ACSES Presidentials 2026"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Presidential elections for CSE department."
                                    },
                                    "departmentId": {
                                        "type": "string",
                                        "example": "dept-cse"
                                    },
                                    "type": {
                                        "type": "string",
                                        "example": "Student Representative"
                                    },
                                    "startTime": {
                                        "type": "string",
                                        "format": "date-time"
                                    },
                                    "endTime": {
                                        "type": "string",
                                        "format": "date-time"
                                    },
                                    "eligibleVoterCount": {
                                        "type": "number",
                                        "example": 350
                                    },
                                    "categories": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "example": [
                                            "President",
                                            "Vice President",
                                            "Secretary"
                                        ]
                                    }
                                },
                                "required": [
                                    "title",
                                    "startTime",
                                    "endTime"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Election created as Draft status."
                    }
                }
            }
        },
        "/elections/{id}": {
            "patch": {
                "summary": "Update election specifications",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "title": {
                                        "type": "string"
                                    },
                                    "description": {
                                        "type": "string"
                                    },
                                    "status": {
                                        "type": "string",
                                        "enum": [
                                            "draft",
                                            "active",
                                            "closed"
                                        ]
                                    },
                                    "startTime": {
                                        "type": "string",
                                        "format": "date-time"
                                    },
                                    "endTime": {
                                        "type": "string",
                                        "format": "date-time"
                                    },
                                    "eligibleVoterCount": {
                                        "type": "number"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Election settings updated successfully."
                    },
                    "404": {
                        "description": "Election not found."
                    }
                }
            }
        },
        "/elections/{id}/categories": {
            "post": {
                "summary": "Add target ballot categories",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Financial Secretary"
                                    }
                                },
                                "required": [
                                    "name"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Ballot category created."
                    }
                }
            }
        },
        "/elections/{id}/results": {
            "get": {
                "summary": "Get ballot results/stats",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Tally metrics containing visual breakdown."
                    }
                }
            }
        },
        "/candidates": {
            "get": {
                "summary": "Fetch all aspirants",
                "responses": {
                    "200": {
                        "description": "List of active aspirants."
                    }
                }
            },
            "post": {
                "summary": "Register candidate",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "electionId": {
                                        "type": "string",
                                        "example": "elec-12345"
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "John Mensah"
                                    },
                                    "position": {
                                        "type": "string",
                                        "example": "President"
                                    },
                                    "color": {
                                        "type": "string",
                                        "example": "#2e7d32"
                                    },
                                    "picture": {
                                        "type": "string",
                                        "description": "Base64 image representation"
                                    },
                                    "department": {
                                        "type": "string",
                                        "example": "Computer Science & Engineering"
                                    }
                                },
                                "required": [
                                    "electionId",
                                    "name",
                                    "position"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Candidate registered successfully."
                    }
                }
            }
        },
        "/candidates/{id}": {
            "delete": {
                "summary": "Remove candidate from ballot",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Aspirant entry cleared."
                    }
                }
            }
        },
        "/votes/cast": {
            "post": {
                "summary": "Submit ballot choices",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "electionId": {
                                        "type": "string",
                                        "example": "elec-12345"
                                    },
                                    "votes": {
                                        "type": "object",
                                        "additionalProperties": {
                                            "type": "string"
                                        },
                                        "example": {
                                            "President": "cand-111",
                                            "General Secretary": "cand-222"
                                        }
                                    }
                                },
                                "required": [
                                    "electionId",
                                    "votes"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Ballot recorded securely with cryptographic fingerprint."
                    }
                }
            }
        },
        "/users": {
            "get": {
                "summary": "Query all user registry profiles",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User registry list (masked details)."
                    }
                }
            }
        },
        "/users/{id}": {
            "get": {
                "summary": "Inspect individual unmasked user",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Unmasked user details. Strictly audit-logged."
                    }
                }
            },
            "patch": {
                "summary": "Update user details",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "studentId": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string"
                                    },
                                    "role": {
                                        "type": "string",
                                        "enum": [
                                            "voter",
                                            "admin",
                                            "auditor"
                                        ]
                                    },
                                    "status": {
                                        "type": "string"
                                    },
                                    "phoneNumber": {
                                        "type": "string"
                                    },
                                    "year": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Registry profile updated successfully."
                    }
                }
            },
            "delete": {
                "summary": "Delete user profile",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User deleted successfully."
                    }
                }
            }
        },
        "/health-checks/diagnostics": {
            "get": {
                "summary": "Cryptographic Audit Trail Health Checks",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Calculates local ledger hashes and ledger validity report."
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        },
        "schemas": {
            "User": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "studentId": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "email": {
                        "type": "string"
                    },
                    "role": {
                        "type": "string"
                    },
                    "status": {
                        "type": "string"
                    }
                }
            },
            "Election": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "status": {
                        "type": "string"
                    },
                    "startTime": {
                        "type": "string"
                    },
                    "endTime": {
                        "type": "string"
                    }
                }
            }
        }
    }
}